# Copie este archivo a .env para personalizar la configuración local.
# Todos los valores tienen default en docker-compose.yml: el compose funciona sin .env.

# --- PostgreSQL ---
POSTGRES_DB=egehaina_acceso
POSTGRES_USER=egehaina
POSTGRES_PASSWORD=egehaina
# Puerto del host mapeado al 5432 del contenedor (5433 para no chocar con un Postgres local).
POSTGRES_PORT=5433

# --- API ---
API_PORT=8080
# Secreto de firma de los JWT (mínimo 32 caracteres). SOLO PARA DEMO.
JWT_SECRET=clave-solo-para-demo-local-cambiar-en-produccion!

# --- Motor facial ---
# Umbral de similitud de coseno: score >= umbral => marcación ACEPTADA.
# 0.40 es un valor razonable para ArcFace/buffalo_l; calibrar con fotos reales (ver README).
FACIAL_UMBRAL_SIMILITUD=0.40
